{
	"name": "hono",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx --watch --env-file=../.env.development --tsconfig tsconfig.json src/app.ts",
		"build": "tsc",
		"prelint": "pnpm -F media build && pnpm -F remark build",
		"lint": "eslint @types src",
		"pretest": "tsc --noEmit && pnpm -F media build && pnpm -F remark build",
		"test": "node --experimental-test-coverage --env-file=../.env.development --env-file=../.env.test --test src/**/*.test.ts"
	},
	"dependencies": {
		"@hono/node-server": "2.0.3",
		"@w0s/env-value-type": "2.0.0",
		"@w0s/file-size-format": "4.0.0",
		"@w0s/html-escape": "5.0.0",
		"@w0s/paapi-item-image-url-parser": "4.0.0",
		"@w0s/sqlite-utility": "3.0.0",
		"better-sqlite3": "12.10.0",
		"dayjs": "1.11.20",
		"ejs": "4.0.1",
		"filenamify": "7.0.1",
		"hono": "4.12.22",
		"kysely": "0.29.2",
		"nodemailer": "8.0.7",
		"sharp": "0.34.5",
		"whatwg-mimetype": "5.0.0",
		"winston": "3.19.0",
		"winston-transport": "4.9.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"@types/ejs": "3.1.5",
		"@types/nodemailer": "8.0.0",
		"@types/whatwg-mimetype": "5.0.0",
		"tsx": "4.21.0"
	},
	"packageManager": "pnpm@11.1.2"
}
